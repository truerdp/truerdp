{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "ADMIN_ALERT_EMAILS",
    "API_BASE_URL",
    "AUTH_COOKIE_DOMAIN",
    "AUTH_COOKIE_MAX_AGE",
    "AUTH_COOKIE_NAME",
    "AUTH_COOKIE_SAME_SITE",
    "AUTH_COOKIE_SECURE",
    "BACKEND_BASE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "COINGATE_API_TOKEN",
    "COINGATE_ENVIRONMENT",
    "COINGATE_PENDING_STATUS_POLL_ATTEMPTS",
    "COINGATE_PENDING_STATUS_POLL_DELAY_MS",
    "COINGATE_RECEIVE_CURRENCY",
    "CORS_ALLOWED_ORIGINS",
    "DASHBOARD_BASE_URL",
    "DATABASE_URL",
    "DODO_DEFAULT_CURRENCY",
    "DODO_PAYMENTS_API_KEY",
    "DODO_PAYMENTS_ENVIRONMENT",
    "DODO_PAYMENTS_WEBHOOK_KEY",
    "EXPIRY_REMINDER_SWEEP_DAYS_AHEAD",
    "EXPIRY_REMINDER_SWEEP_INTERVAL_MINUTES",
    "DODO_TAX_CATEGORY",
    "INTERNAL_API_URL",
    "JWT_SECRET",
    "NEXT_PUBLIC_ADMIN_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_DASHBOARD_URL",
    "NEXT_PUBLIC_ENABLE_QUERY_DEVTOOLS",
    "NEXT_PUBLIC_SANITY_DATASET",
    "NEXT_PUBLIC_SANITY_PROJECT_ID",
    "NEXT_PUBLIC_SANITY_STUDIO_URL",
    "NEXT_PUBLIC_TAWK_TO_PROPERTY_ID",
    "NEXT_PUBLIC_TAWK_TO_WIDGET_ID",
    "NEXT_PUBLIC_WEB_URL",
    "NODE_ENV",
    "PASSWORD_RESET_EXPOSE_LINK",
    "PORT",
    "RESOURCE_CREDENTIALS_SECRET",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "RESEND_REPLY_TO_EMAIL",
    "SANITY_API_TOKEN",
    "SANITY_API_VERSION",
    "SANITY_BROWSER_TOKEN",
    "SANITY_DATASET",
    "SANITY_DRAFT_SECRET",
    "SANITY_PROJECT_ID",
    "SANITY_REVALIDATE_SECRET",
    "VERCEL_PROJECT_PRODUCTION_URL",
    "WEB_BASE_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
