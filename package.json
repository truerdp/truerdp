{
  "name": "truerdp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "node scripts/workflow.mjs dev",
    "dev:frontend": "node scripts/workflow.mjs dev:frontend",
    "dev:frontend:no-infisical": "node scripts/workflow.mjs dev:frontend:no-infisical",
    "dev:backend": "node scripts/workflow.mjs dev:backend",
    "dev:backend:restart": "node scripts/workflow.mjs dev:backend:restart",
    "dev:backend:rebuild": "node scripts/workflow.mjs dev:backend:rebuild",
    "dev:stop": "node scripts/workflow.mjs dev:stop",
    "infisical:render:backend": "infisical agent --config deploy/infisical/runtime/backend-agent.yaml",
    "prod:backend": "node scripts/workflow.mjs prod:backend",
    "prod:backend:preflight": "node scripts/workflow.mjs prod:backend:preflight",
    "prod:backend:refresh": "node scripts/workflow.mjs prod:backend:refresh",
    "prod:down": "docker compose -f docker-compose.prod.yml down",
    "prod:logs": "docker compose -f docker-compose.prod.yml logs -f backend db",
    "tunnel:backend": "ngrok http 3003",
    "doctor": "node scripts/workflow.mjs doctor",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3",
    "kill-port": "^2.0.1"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20"
  }
}
