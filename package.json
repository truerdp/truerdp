{
  "name": "truerdp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:frontend": "turbo dev --filter=web --filter=dashboard --filter=admin",
    "docker:create": "docker compose up -d --build",
    "dev:docker": "docker compose up -d --force-recreate backend db && pnpm run dev:frontend",
    "dev:backend:restart": "docker compose up -d --force-recreate backend",
    "dev:stop": "docker compose down && lsof -ti :3000,3001,3002,3003 | xargs kill 2>/dev/null || true",
    "ngrok:backend": "ngrok http 3003",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "^0.45.1"
    }
  }
}
