DATABASE_URL=postgres://postgres:postgres@localhost:5432/truerdp
PORT=3003
JWT_SECRET=change-this-in-production
RESOURCE_CREDENTIALS_SECRET=change-this-too
AUTH_COOKIE_NAME=truerdp_session
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_MAX_AGE=604800
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
# Optional: expose reset link in forgot-password API response outside local dev
PASSWORD_RESET_EXPOSE_LINK=false

# Resend transactional email
# Use a real re_ API key in production, or a test key with RESEND_BASE_URL for the local emulator.
RESEND_API_KEY=
RESEND_FROM_EMAIL=TrueRDP <onboarding@resend.dev>
RESEND_REPLY_TO_EMAIL=
RESEND_BASE_URL=

# Dodo Payments — environment for hosted checkout (test_mode or live_mode)
DODO_PAYMENTS_ENVIRONMENT=test_mode
# Dodo Payments API key (Test or Live based on environment)
DODO_PAYMENTS_API_KEY=
# Webhook signing secret from Dodo Payments dashboard
DODO_PAYMENTS_WEBHOOK_KEY=
# Canonical billing currency used for synced catalog prices and checkout sessions
DODO_DEFAULT_CURRENCY=USD
# Public Web URL used to build return URLs for hosted checkout redirects
WEB_BASE_URL=http://localhost:3000
# Public dashboard URL used in transactional emails
DASHBOARD_BASE_URL=http://localhost:3001
# Comma-separated recipients for operational alerts (payment failures, etc.)
ADMIN_ALERT_EMAILS=
# Optional: Map planPricingId to Dodo product_id for checkout sessions (JSON object)
# Example: {"1":"prod_abc","2":"prod_def"}
DODO_PRODUCT_MAP=

# CoinGate — hosted crypto checkout
# Environment: sandbox (test) or live (production)
COINGATE_ENVIRONMENT=sandbox
# API token from CoinGate merchant dashboard
COINGATE_API_TOKEN=
# Settlement target currency (or DO_NOT_CONVERT to keep paid currency)
COINGATE_RECEIVE_CURRENCY=DO_NOT_CONVERT
# Public backend URL used by CoinGate callback_url
BACKEND_BASE_URL=http://localhost:3003
# Optional: retry reads when CoinGate callback arrives while status is still pending
COINGATE_PENDING_STATUS_POLL_ATTEMPTS=4
COINGATE_PENDING_STATUS_POLL_DELAY_MS=500
