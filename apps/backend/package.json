{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod-local": "dotenv_config_path=.env.production.local node -r dotenv/config dist/index.js",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "tsx node_modules/drizzle-kit/bin.cjs push",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:reset": "tsx src/scripts/reset-db.ts",
    "db:studio": "tsx node_modules/drizzle-kit/bin.cjs studio",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "openapi:audit": "tsx src/scripts/audit-openapi-response-schemas.ts",
    "openapi:export": "tsx src/scripts/export-openapi.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1076.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "better-auth": "^1.6.9",
    "dodopayments": "^2.28.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "fastify-raw-body": "^5.0.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "resend": "^6.12.2",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
